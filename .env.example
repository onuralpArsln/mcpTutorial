GOOGLE_API_KEY=buraya_api_keyini_yaz

# --- 1. SLOT SELECTORS ---
# Point these to any of the Configuration IDs defined below (OLLAMA_SMALL /  GEMINI_FLASH )
CHEAP_CONFIG=OLLAMA_SMALL
EXPENSIVE_CONFIG=GEMINI_FLASH

# --- 2. EXPANDABLE MODEL PROFILES ---

# Profile: OLLAMA_SMALL (Local)
OLLAMA_SMALL_PROVIDER=ollama
OLLAMA_SMALL_MODEL=llama3.2:3b
OLLAMA_SMALL_BASE_URL=http://localhost:11434

# Profile: GEMINI_FLASH (Cloud)
GEMINI_FLASH_PROVIDER=gemini
GEMINI_FLASH_MODEL=gemini-1.5-flash
# BACKUP_MODEL_ID=gemini-2.5-flash-lite (20 req/day quota)
BACKUP_MODEL_ID=gemini-1.5-flash

# Default fallback role selection
DEFAULT_LLM_ROLE=cheap


# --- AI Retry and Wait Configurations ---
LLM_MAX_RETRIES=2
LLM_RETRY_WAIT_JITTER=true
